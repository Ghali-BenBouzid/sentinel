# Copy this file to `.env` and fill in your key. `.env` is gitignored - never
# commit real secrets. pydantic-settings loads `.env` automatically, so no
# `export` is needed to run the agent layer.

# Which LLM provider to use: groq (default, free tier) or anthropic
SENTINEL_LLM_PROVIDER=groq

# Groq free-tier key from https://console.groq.com  (GROK_API_KEY is accepted as an alias)
# NOTE: "Groq" (groq.com, fast Llama inference - what this app uses) is a DIFFERENT
# service from xAI's "Grok" (x.ai). This key is for Groq, not Grok.
GROQ_API_KEY=

# Anthropic/Claude key (only needed if SENTINEL_LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
